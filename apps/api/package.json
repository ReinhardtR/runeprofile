{
  "name": "@runeprofile/api",
  "exports": {
    "./client": {
      "import": {
        "types": "./dist/lib/api-client.d.ts"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typegen": "wrangler types",
    "dev": "wrangler dev src/index.ts --remote",
    "dev:api-client": "tsc -p tsconfig.build.json --watch",
    "discord:register": "tsx --env-file=.dev.vars src/internal/discord/register.ts",
    "discord:register:prod": "tsx --env-file=.env src/internal/discord/register.ts",
    "ngrok": "ngrok http 8787",
    "build": "tsc -p tsconfig.build.json",
    "deploy": "pnpm run typecheck && pnpm run discord:register:prod && wrangler deploy --minify",
    "test": "vitest --ui --watch"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.18.4",
    "@hono/zod-validator": "^0.4.3",
    "@runeprofile/db": "workspace:*",
    "@runeprofile/runescape": "workspace:*",
    "@scalar/client-side-rendering": "0.1.6",
    "@scalar/hono-api-reference": "^0.10.13",
    "@scalar/types": "^0.9.5",
    "discord-api-types": "^0.38.28",
    "discord-hono": "^0.20.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.31",
    "hono-rate-limiter": "^0.5.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^25.0.3",
    "@vitest/ui": "3.2.7",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.20.6",
    "vitest": "^3.2.7",
    "wrangler": "^4.59.2"
  }
}
